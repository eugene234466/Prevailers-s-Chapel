// /api/devotional.js
import fetch from 'node-fetch';

export default async function handler(req, res) {
    if (req.method !== 'POST') {
        return res.status(405).json({ error: 'Method not allowed' });
    }

    const { verseText, verseRef } = req.body;

    if (!verseText || !verseRef) {
        return res.status(400).json({ error: 'Missing verseText or verseRef' });
    }

    const API_KEY = process.env.ANTHROPIC_API_KEY;
    if (!API_KEY) {
        return res.status(500).json({ error: 'Server misconfigured: missing API key' });
    }

    try {
        // Construct the prompt for Claude
        const prompt = `
You are a Christian pastor. Write a devotional for the following verse:

Verse: ${verseRef} - "${verseText}"

Return the result in JSON format exactly like this:
{
  "title": "Devotional title here",
  "message": ["Paragraph 1", "Paragraph 2", "..."],
  "reflections": ["Question 1", "Question 2", "..."],
  "prayer": "Prayer text here"
}

Make it encouraging, concise, and faithful to scripture.
`;

        const response = await fetch('https://api.anthropic.com/v1/complete', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
                'X-API-Key': API_KEY
            },
            body: JSON.stringify({
                model: 'claude-v1',
                prompt,
                max_tokens_to_sample: 1000,
                temperature: 0.7,
            })
        });

        const data = await response.json();

        // Claude's output text may be in `completion` field
        let text = data.completion || '';

        // Try to extract JSON from Claude output
        let parsed;
        try {
            parsed = JSON.parse(text);
        } catch (err) {
            // fallback if Claude returns extra text
            const match = text.match(/\{[\s\S]*\}/);
            parsed = match ? JSON.parse(match[0]) : null;
        }

        if (!parsed || !parsed.message) {
            throw new Error('Invalid AI response');
        }

        res.status(200).json(parsed);

    } catch (err) {
        console.error('Devotional generation error:', err);
        res.status(500).json({ error: 'Failed to generate devotional' });
    }
}