// /api/devotional.js

export default async function handler(req, res) {
    // Enable CORS
    res.setHeader('Access-Control-Allow-Credentials', true);
    res.setHeader('Access-Control-Allow-Origin', '*');
    res.setHeader('Access-Control-Allow-Methods', 'GET,OPTIONS,PATCH,DELETE,POST,PUT');
    res.setHeader(
        'Access-Control-Allow-Headers',
        'X-CSRF-Token, X-Requested-With, Accept, Accept-Version, Content-Length, Content-MD5, Content-Type, Date, X-Api-Version'
    );

    if (req.method === 'OPTIONS') {
        res.status(200).end();
        return;
    }

    if (req.method !== 'POST') {
        return res.status(405).json({ error: 'Method not allowed' });
    }

    const { verseText, verseRef } = req.body;

    if (!verseText || !verseRef) {
        return res.status(400).json({ error: 'Missing verseText or verseRef' });
    }

    const API_KEY = process.env.ANTHROPIC_API_KEY;
    if (!API_KEY) {
        console.error('Missing ANTHROPIC_API_KEY environment variable');
        return res.status(500).json({ error: 'Server misconfigured: missing API key' });
    }

    try {
        // Construct the prompt for Claude
        const prompt = `You are a Christian pastor writing a daily devotional. Write an encouraging, thoughtful devotional based on this verse:

Verse: ${verseRef} - "${verseText}"

IMPORTANT: Your response must be ONLY a valid JSON object with this exact structure (no other text before or after):
{
  "title": "A compelling, relevant title for this devotional (5-8 words)",
  "message": [
    "First paragraph introducing the verse and its context (2-3 sentences)",
    "Second paragraph with practical application for daily life (2-3 sentences)",
    "Third paragraph with encouragement and hope (2-3 sentences)"
  ],
  "reflections": [
    "First reflection question that prompts personal application",
    "Second reflection question about sharing with others",
    "Third reflection question about taking action"
  ],
  "prayer": "A heartfelt prayer based on this scripture (3-4 sentences)"
}

Make it:
- Faithful to scripture
- Encouraging and practical
- Written in warm, pastoral language
- Appropriate for a diverse Christian audience`;

        console.log('Calling Anthropic API for verse:', verseRef);

        const response = await fetch('https://api.anthropic.com/v1/messages', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
                'x-api-key': API_KEY,
                'anthropic-version': '2023-06-01'
            },
            body: JSON.stringify({
                model: 'claude-3-haiku-20240307',
                max_tokens: 1024,
                temperature: 0.7,
                system: "You are a helpful Christian pastor. You always respond with valid JSON only, no additional text.",
                messages: [
                    {
                        role: 'user',
                        content: prompt
                    }
                ]
            })
        });

        if (!response.ok) {
            const errorText = await response.text();
            console.error('Anthropic API error:', response.status, errorText);
            throw new Error(`API responded with status ${response.status}: ${errorText}`);
        }

        const data = await response.json();
        
        // Extract the text from Claude's response
        let text = data.content[0].text;
        
        // Clean the text - remove any potential markdown code blocks
        text = text.replace(/```json\n?/g, '').replace(/```\n?/g, '').trim();

        console.log('Raw AI response:', text.substring(0, 200) + '...');

        // Try to extract JSON from Claude output
        let parsed;
        try {
            // First attempt: parse the entire response
            parsed = JSON.parse(text);
        } catch (err) {
            console.log('Failed direct parse, trying to extract JSON object...');
            // Second attempt: find JSON object in the text
            const match = text.match(/\{[\s\S]*\}/);
            if (match) {
                try {
                    parsed = JSON.parse(match[0]);
                } catch (innerErr) {
                    console.error('Failed to parse JSON from match:', match[0]);
                }
            }
        }

        // Validate the parsed object has required fields
        if (!parsed) {
            console.error('No valid JSON found in response');
            throw new Error('Invalid AI response: No JSON found');
        }

        // Ensure all required fields exist
        const validated = {
            title: parsed.title || `Meditation on ${verseRef}`,
            message: Array.isArray(parsed.message) ? parsed.message : [
                `Today we reflect on ${verseRef}: "${verseText}"`,
                "This verse reminds us of God's faithfulness and love.",
                "May it encourage you throughout your day."
            ],
            reflections: Array.isArray(parsed.reflections) ? parsed.reflections : [
                "How does this verse speak to your current situation?",
                "What is God revealing to you through this scripture?",
                "How can you apply this truth today?"
            ],
            prayer: parsed.prayer || `Lord, thank You for Your Word in ${verseRef}. Help us to live out this truth today. Amen.`
        };

        console.log('✅ Successfully generated devotional for:', verseRef);
        res.status(200).json(validated);

    } catch (err) {
        console.error('Devotional generation error:', err);
        res.status(500).json({ 
            error: 'Failed to generate devotional',
            details: err.message 
        });
    }
}